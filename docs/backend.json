
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Extended user information for library visitors and staff.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "isBlocked": { "type": "boolean" },
        "program": { "type": "string" },
        "college": { "type": "string" },
        "isEmployee": { "type": "boolean" },
        "employeeType": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "isBlocked"]
    },
    "Visit": {
      "title": "Library Visit",
      "description": "Record of a single library visit.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "program": { "type": "string" },
        "college": { "type": "string" },
        "isEmployee": { "type": "boolean" },
        "employeeType": { "type": "string" },
        "reason": { "type": "string" },
        "timestamp": { "type": "object" },
        "date": { "type": "string" },
        "aiClassified": { "type": "string" },
        "aiSuggestion": { "type": "string" },
        "aiExplanation": { "type": "string" }
      },
      "required": ["uid", "reason", "date"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/visits/{visitId}": {
      "schema": "Visit",
      "description": "Visitor log entries."
    }
  }
}
